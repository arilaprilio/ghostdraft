# GhostDraft — Firebase Configuration
# Copy to .env and fill in values from Firebase Console > Project settings > Web app

FIREBASE_API_KEY=PASTE_YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=PASTE_YOUR_PROJECT.firebaseapp.com
FIREBASE_DATABASE_URL=https://PASTE_YOUR_PROJECT-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=PASTE_YOUR_PROJECT
FIREBASE_STORAGE_BUCKET=PASTE_YOUR_PROJECT.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=PASTE_YOUR_SENDER_ID
FIREBASE_APP_ID=1:PASTE_YOUR_SENDER_ID:web:PASTE_YOUR_APP_ID
FIREBASE_MEASUREMENT_ID=PASTE_YOUR_MEASUREMENT_ID
